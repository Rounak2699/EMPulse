# ─────────────────────────────────────────────
#  MindScope Backend — Environment Variables
# ─────────────────────────────────────────────

# Your Resend API key (from resend.com → API Keys)
RESEND_API_KEY=re_RrdS6eRm_AoFcBStaMDfJHXbJ6pFkobZa

# The "From" address — must be a verified domain in your Resend account
# e.g.  reports@yourdomain.com  OR  onboarding@resend.dev (for testing)
FROM_EMAIL=onboarding@resend.dev

# Admin email — where every PDF report will be delivered
ADMIN_EMAIL=excelmindpulse@gmail.com

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Allowed frontend origin for CORS  (use * to allow all during dev)
# e.g.  http://localhost:5500  or  https://yourfrontend.com
FRONTEND_ORIGIN=http://127.0.0.1:5500/MindScopeFinal.html
